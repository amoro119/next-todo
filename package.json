{
  "name": "next-todo-localfirst",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run next:dev",
    "dev:free": "NEXT_PUBLIC_DISTRIBUTION=free npm run dev",
    "dev:premium": "NEXT_PUBLIC_DISTRIBUTION=premium npm run dev",
    "dev:local": "npm run next:dev",
    "dev:local:free": "NEXT_PUBLIC_DISTRIBUTION=free npm run next:dev",
    "dev:local:premium": "NEXT_PUBLIC_DISTRIBUTION=premium npm run next:dev",
    "db:migrate:remote": "dotenv -e .env.local -- sh -c 'supabase db push --db-url \"$DATABASE_URL\"'",
    "next:dev": "next dev -p 3000 -H 0.0.0.0",
    "build": "npm run next:build",
    "next:build": "next build",
    "lint": "next lint",
    "test": "vitest run",
    "test:db-migration": "vitest run lib/db/__tests__/legacyMigration.test.ts --environment node",
    "test:watch": "vitest",
    "write-server": "echo \"'write-server' is deprecated, use Supabase Edge Functions instead.\" && exit 0"
  },
